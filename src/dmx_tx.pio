.program dmx_tx
.side_set 1 opt

; 8 data bits, no parity, 2 stop bits. Configure the state machine clock
; to 8 * baud so each bit cell lasts eight PIO cycles.
pull block side 1
set x, 7 side 0 [7]      ; start bit
bitloop:
out pins, 1 [6]
jmp x-- bitloop
nop side 1 [6]           ; stop bit 1
nop side 1 [6]           ; stop bit 2
